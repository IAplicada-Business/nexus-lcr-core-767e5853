# VPS
VPS_IP=SEU_IP_AQUI

# n8n
N8N_USER=admin
N8N_PASSWORD=SENHA_FORTE_AQUI

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_KEY=eyJ...

# Gestta
GESTTA_EMAIL=seu@email.com
GESTTA_PASSWORD=senha_gestta

# SCI Único
SCI_EMAIL=seu@email.com
SCI_PASSWORD=senha_sci

# LevelDrive
LEVELDRIVE_EMAIL=seu@email.com
